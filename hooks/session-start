#!/usr/bin/env bash
# SessionStart hook for FAAH plugin
# Injects faah-init skill content into session context

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read faah-init skill content
init_file="${PLUGIN_ROOT}/skills/faah-init/SKILL.md"
if [ ! -f "$init_file" ]; then
    echo "Error: $init_file not found" >&2
    exit 1
fi

init_content=$(cat "$init_file")
session_context="<faah-context>\n${init_content}\n</faah-context>"

# Generate JSON safely using jq
jq -n --arg ctx "$session_context" \
'{
  additional_context: $ctx,
  hookSpecificOutput: {
    hookEventName: "SessionStart",
    additionalContext: $ctx
  }
}'

exit 0
